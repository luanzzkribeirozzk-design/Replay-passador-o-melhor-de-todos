<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <!-- Amarelo Neon com 80% de opacidade (CC) -->
            <gradient android:startColor="#CCAAFF00" android:endColor="#CC88CC00" android:angle="135" />
            <corners android:radius="16dp" />
            <stroke android:width="2dp" android:color="#FFFFFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <!-- Amarelo Neon com 60% de opacidade (99) para ver o fundo -->
            <gradient android:startColor="#99CCFF00" android:endColor="#99AAFF00" android:angle="135" />
            <corners android:radius="16dp" />
            <padding android:left="10dp" android:top="10dp" android:right="10dp" android:bottom="10dp" />
            <!-- Borda neon sólida para destacar -->
            <stroke android:width="1dp" android:color="#CCFF00" />
        </shape>
    </item>
</selector>
