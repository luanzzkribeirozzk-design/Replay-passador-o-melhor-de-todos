<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#0A1A3A" />
            <corners android:radius="10dp" />
            <stroke android:width="2dp" android:color="#00CFFF" />
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#05080F" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="#1A2A4A" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0D0A2E"
                android:endColor="#0A1A3A"
                android:angle="135" />
            <corners android:radius="10dp" />
            <stroke android:width="2dp" android:color="#00CFFF" />
        </shape>
    </item>
</selector>
