<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#55220044" />
            <corners android:radius="50dp" />
            <stroke android:width="2dp" android:color="#FF00FF" />
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#22000033" />
            <corners android:radius="50dp" />
            <stroke android:width="1dp" android:color="#440055" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#33110033" />
            <corners android:radius="50dp" />
            <stroke android:width="2dp" android:color="#BB00CC" />
        </shape>
    </item>
</selector>
