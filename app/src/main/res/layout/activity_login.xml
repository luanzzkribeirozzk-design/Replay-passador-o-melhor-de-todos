<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- BACKGROUND IMAGE -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_volpp"
        android:scaleType="centerCrop"
        android:alpha="1.0" />

    <com.replayx.app.ui.ParticleView
        android:id="@+id/particleView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/mainContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp">

            <!-- LOGO -->
            <LinearLayout
                android:id="@+id/logoContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="80dp"
                android:layout_marginBottom="50dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DEV WILL"
                    android:textColor="#FFFFFF"
                    android:textSize="54sp"
                    android:shadowColor="#CCFF00"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="30"
                    android:fontFamily="sans-serif-black"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PREMIUM BYPASS SYSTEM"
                    android:textColor="#CCFF00"
                    android:textSize="12sp"
                    android:letterSpacing="0.5"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- CARD LOGIN -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_login"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACESSO COM KEY"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="24dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="HIDE STREAM"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:fontFamily="monospace" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchHideStreamLogin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KEY DE ACESSO"
                    android:textColor="#AAFF00"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/etKey"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/input_bg"
                    android:textColor="#FFFFFF"
                    android:hint="usuario>senha"
                    android:padding="12dp"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:inputType="text"
                    android:imeOptions="actionDone"
                    android:layout_marginBottom="20dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchRemember"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lembrar key"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:layout_marginStart="10dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="INICIAR BYPASS"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_primary"
                    android:elevation="8dp"
                    android:stateListAnimator="@null"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:layout_marginTop="12dp"
                    android:visibility="gone" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="12dp"
                    android:indeterminateTint="#CCFF00"
                    android:visibility="gone" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEV WILL  ·  DEV WILL"
                android:textColor="#222200"
                android:textSize="9sp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </ScrollView>

    <!-- SPLASH SCREEN PRETA -->
    <FrameLayout
        android:id="@+id/splashScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:elevation="100dp"
        android:visibility="visible">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="VERIFICANDO"
            android:textColor="#222222"
            android:textSize="10sp"
            android:fontFamily="monospace" />
    </FrameLayout>

</FrameLayout>
