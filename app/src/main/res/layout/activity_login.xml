<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0400">

    <!-- SPLASH SCREEN PRETA -->
    <FrameLayout
        android:id="@+id/splashScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:elevation="100dp"
        android:visibility="visible"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:alpha="0.5">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VERIFICANDO"
                android:textColor="#222222"
                android:textSize="10sp"
                android:letterSpacing="0.4"
                android:fontFamily="monospace" />

        </LinearLayout>

    </FrameLayout>

    <com.replayx.app.ui.ParticleView
        android:id="@+id/particleView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp"
            android:minHeight="100dp">

            <!-- LOGO -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="48dp"
                android:layout_marginBottom="36dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BY: Yguix SCRIPT"
                    android:textColor="#7A3000"
                    android:textSize="11sp"
                    android:letterSpacing="0.4"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Yguix SCRIPT"
                    android:textColor="#FF6B00"
                    android:textSize="42sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BYPASS  ·  BYPASS Yguix"
                    android:textColor="#5A2000"
                    android:textSize="10sp"
                    android:letterSpacing="0.2"
                    android:gravity="center"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- COLOR SELECTOR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="12dp"
                android:background="#120800"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btnColorGreen"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/color_btn_green"
                    android:text="🟢"
                    android:textSize="20sp"
                    android:layout_margin="6dp" />

                <Button
                    android:id="@+id/btnColorPurple"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/color_btn_purple"
                    android:text="🟣"
                    android:textSize="20sp"
                    android:layout_margin="6dp" />

                <Button
                    android:id="@+id/btnColorBlue"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/color_btn_blue"
                    android:text="🔵"
                    android:textSize="20sp"
                    android:layout_margin="6dp" />

                <Button
                    android:id="@+id/btnColorRed"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/color_btn_red"
                    android:text="🔴"
                    android:textSize="20sp"
                    android:layout_margin="6dp" />

            </LinearLayout>

            <!-- CARD LOGIN -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_login"
                android:padding="20dp">

                <!-- TITULO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACESSO COM KEY"
                    android:textColor="#FF6B00"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="16dp" />

                <!-- HIDE STREAM -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="HIDE STREAM"
                        android:textColor="#FF6B00"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.1" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchHideStreamLogin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <!-- CAMPO KEY -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KEY DE ACESSO"
                    android:textColor="#5A2000"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etKey"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/input_bg"
                    android:textColor="#FF6B00"
                    android:textColorHint="#3A1500"
                    android:hint="usuario>senha"
                    android:padding="12dp"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:inputType="text"
                    android:imeOptions="actionDone"
                    android:layout_marginBottom="12dp" />

                <!-- LEMBRAR KEY -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchRemember"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lembrar key"
                        android:textColor="#7A3000"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:layout_marginStart="10dp" />

                </LinearLayout>

                <!-- BOTAO ENTRAR -->
                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="ENTRAR"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:background="@drawable/btn_primary"
                    android:stateListAnimator="@null" />

                <!-- ERRO -->
                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#FF6B00"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:layout_marginTop="12dp"
                    android:visibility="gone" />

                <!-- LOADING -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="12dp"
                    android:indeterminateTint="#FF6B00"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- TIMER (aparece depois do login) -->
            <LinearLayout
                android:id="@+id/layoutTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_timer"
                android:padding="16dp"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TEMPO RESTANTE"
                    android:textColor="#5A2000"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="00d 00h 00m 00s"
                    android:textColor="#FF6B00"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvKeyUser"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#5A2000"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yguix SCRIPT  ·  BYPASS Yguix"
                android:textColor="#3A1000"
                android:textSize="9sp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>
