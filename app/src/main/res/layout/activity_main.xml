<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#010A01">

    <com.replayx.app.ui.ParticleView
        android:id="@+id/particleView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#00000088"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="44dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PASSADOR DE"
                android:textColor="#005500"
                android:textSize="11sp"
                android:letterSpacing="0.4"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REPLAY X"
                android:textColor="#00FF41"
                android:textSize="36sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="FREE FIRE  ·  BYPASS SYSTEM"
                    android:textColor="#004400"
                    android:textSize="10sp"
                    android:letterSpacing="0.2" />

                <TextView
                    android:id="@+id/tvShizukuStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● VERIFICANDO"
                    android:textColor="#FFD700"
                    android:textSize="10sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvApplying"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aplicando bypass..."
                android:textColor="#00FF41"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp"
                android:visibility="gone" />

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#00FF41" />

        <!-- HIDE STREAM CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#00000099"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HIDE STREAM"
                    android:textColor="#00FF41"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvHideStreamStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HIDE STREAM: OFF"
                    android:textColor="#444444"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <Switch
                android:id="@+id/switchHideStream"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                android:track="@drawable/switch_track"
                android:thumb="@drawable/switch_thumb"
                android:showText="false" />

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#003300" />

        <!-- BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#00000066">

            <Button
                android:id="@+id/btnBypassMaxToNormal"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="BYPASS  FFM = FFN"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:background="@drawable/btn_primary"
                android:stateListAnimator="@null"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Free Fire MAX  →  Free Fire Normal"
                android:textColor="#006600"
                android:textSize="10sp"
                android:layout_gravity="center"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnBypassNormalToMax"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="BYPASS  FFN = FFM"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:background="@drawable/btn_secondary"
                android:stateListAnimator="@null"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Free Fire Normal  →  Free Fire MAX"
                android:textColor="#006600"
                android:textSize="10sp"
                android:layout_gravity="center"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnClearLog"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="CLR"
                android:textColor="#00FF41"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/btn_clear"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#003300" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#00000088"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="root@replayx:~$ bypass_log"
                android:textColor="#00AA22"
                android:textSize="10sp"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0"
                android:textColor="#003311"
                android:textSize="10sp" />

        </LinearLayout>

        <ScrollView
            android:id="@+id/scrollLog"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#00000099"
            android:padding="12dp"
            android:scrollbars="none">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text=""
                android:textColor="#00FF41"
                android:textSize="11sp"
                android:lineSpacingExtra="2dp" />

        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#00000088"
            android:paddingVertical="8dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REPLAY X  ·  FREE FIRE BYPASS SYSTEM"
                android:textColor="#003300"
                android:textSize="9sp"
                android:letterSpacing="0.15" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
