<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:orientation="vertical">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#12121A"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="42dp"
        android:paddingBottom="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PASSADOR DE"
            android:textColor="#6A0DAD"
            android:textSize="12sp"
            android:letterSpacing="0.3"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REPLAY X"
            android:textColor="#BF00FF"
            android:textSize="30sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FREE FIRE  •  BYPASS SYSTEM"
            android:textColor="#5C3D7A"
            android:textSize="10sp"
            android:letterSpacing="0.2"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tvShizukuStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● VERIFICANDO SHIZUKU..."
            android:textColor="#FFD700"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginTop="10dp" />

    </LinearLayout>

    <!-- NEON LINE -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#8B00FF" />

    <!-- BOTOES -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp"
        android:background="#0A0A0F">

        <!-- BTN 1: MAX -> NORMAL -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#12121A"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp">

                <Button
                    android:id="@+id/btnBypassMaxToNormal"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="BYPASS  FFM = FFN"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:background="@drawable/btn_primary"
                    android:stateListAnimator="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Free Fire MAX  →  Free Fire Normal"
                    android:textColor="#6A0DAD"
                    android:textSize="10sp"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- BTN 2: NORMAL -> MAX -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#12121A"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp">

                <Button
                    android:id="@+id/btnBypassNormalToMax"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="BYPASS  FFN = FFM"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:background="@drawable/btn_secondary"
                    android:stateListAnimator="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Free Fire Normal  →  Free Fire MAX"
                    android:textColor="#6A0DAD"
                    android:textSize="10sp"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- BTN 3: LIMPAR -->
        <Button
            android:id="@+id/btnClearLog"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="⌫  LIMPAR TERMINAL"
            android:textColor="#7B2FBE"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/btn_clear"
            android:stateListAnimator="@null" />

    </LinearLayout>

    <!-- DIVIDER -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A1A2E" />

    <!-- TERMINAL HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D0D18"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="▶  TERMINAL  //  BYPASS LOG"
            android:textColor="#6A0DAD"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.15" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0"
            android:textColor="#3D1A6B"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- LOG -->
    <ScrollView
        android:id="@+id/scrollLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#04040E"
        android:padding="12dp"
        android:scrollbars="none">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text=""
            android:textColor="#00FF41"
            android:textSize="11sp"
            android:lineSpacingExtra="3dp" />

    </ScrollView>

    <!-- FOOTER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D0D18"
        android:paddingVertical="8dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REPLAY X  •  BYPASS SYSTEM  •  FREE FIRE"
            android:textColor="#2A1A4E"
            android:textSize="9sp"
            android:letterSpacing="0.2" />

    </LinearLayout>

</LinearLayout>
